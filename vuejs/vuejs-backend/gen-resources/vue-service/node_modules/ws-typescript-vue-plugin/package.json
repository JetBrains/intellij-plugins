    "../../../../../plugins/JavaScriptLanguage/javascript-backend/src-js/tscplugin"
  ],
  "dependencies": {
    "typescript": "5.4.5",
    "tsc-ide-plugin": "workspace:*",
    "@vue/typescript-plugin": "3.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "@vercel/ncc": "0.44.0"
  },
  "scripts": {
    "build:clean": "npm run clean && npm run build",
    "clean": "rm -rf ../../gen-resources/vue-service",
    "build": "ncc build src/index.ts -o ../../gen-resources/vue-service/node_modules/ws-typescript-vue-plugin -m --no-cache && cp -r ./package.json ../../gen-resources/vue-service/node_modules/ws-typescript-vue-plugin"
  }
}
