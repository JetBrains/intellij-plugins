{
  "name": "@vue/typescript-plugin",
  "version": "3.3.5",
  "private": true,
  "main": "dist/index.js",
  "devDependencies": {
    "@vue/typescript-plugin": "3.3.5",
    "@vercel/ncc": "0.38.4"
  },
  "scripts": {
    "build:clean": "npm run clean && npm run build",
    "clean": "rm -rf ./dist && rm -rf ./types",
    "build": "npm run build:plugin && npm run copy:types",
    "build:plugin": "ncc build node_modules/@vue/typescript-plugin -m --no-cache",
    "copy:types": "cp -R ./node_modules/@vue/language-core/types ./types"
  }
}
