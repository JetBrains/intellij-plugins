<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <module name="intellij.python.psi.impl"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="Pythonid">
    <typeProvider implementation="com.intellij.protobuf.python.types.PbPythonTypeProvider"/>
    <pyModuleMembersProvider implementation="com.intellij.protobuf.python.types.PbPythonModuleMembersProvider"/>
    <typeCheckerExtension implementation="com.intellij.protobuf.python.types.PbPythonTypeCheckerExtension"/>
  </extensions>
</idea-plugin>
