  wkt.field_descriptor_field.<caret>

  # --- Option ---
  # EXPECT-COMPLETE: name, value, OptionFunction, MessageFunction
  wkt.option_field.<caret>

  # --- Mixin ---
  # EXPECT-COMPLETE: name, root, MixinFunction, MessageFunction
  wkt.mixin_field.<caret>

  # --- SourceContext ---
  # EXPECT-COMPLETE: file_name, SourceContextFunction, MessageFunction
  wkt.source_context_field.<caret>
