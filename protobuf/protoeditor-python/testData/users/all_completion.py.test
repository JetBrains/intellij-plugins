# EXPECT-COMPLETE: SomeMessage, ScalarTypesMessage, SomeEnum, WellKnownTypesMessage, MyOptions, SharedMessage, file_opt, message_opt, complex_message_opt, field_opt, source_retention_opt, enum_opt, enum_value_opt
from $importName import <caret>

# EXPECT-COMPLETE: Timestamp
from google.protobuf.timestamp_pb2 import <caret>

# EXPECT-COMPLETE: protobuf
from google.<caret>

# EXPECT-COMPLETE: any_pb2, api_pb2, duration_pb2, empty_pb2, field_mask_pb2, source_context_pb2, struct_pb2, timestamp_pb2, type_pb2, wrappers_pb2
from google.protobuf.<caret>

# Actual imports to use later
import $importName
from $importName import SharedMessage, MyOptions, SomeEnum, ScalarTypesMessage, SomeMessage, WellKnownTypesMessage, MyOptions

def run():
  # EXPECT-COMPLETE: SomeMessage, ScalarTypesMessage, SomeEnum, WellKnownTypesMessage, MyOptions, SharedMessage, file_opt, message_opt, complex_message_opt, field_opt, source_retention_opt, enum_opt, enum_value_opt
  $importName.<caret>

  msg = SomeMessage()

  # --- Message fields ---
