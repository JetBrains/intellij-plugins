  wkt.api_field.<caret>

  # --- Type ---
  # EXPECT-COMPLETE: name, fields, oneofs, options, source_context, syntax, TypeFunction, MessageFunction
  wkt.type_field.<caret>

  # --- Method ---
  # EXPECT-COMPLETE: name, request_type_url, request_streaming, response_type_url, response_streaming, options, syntax, MethodFunction, MessageFunction
  wkt.method_field.<caret>

  # --- Enum Descriptor ---
  # EXPECT-COMPLETE: name, enumvalue, options, source_context, syntax, EnumFunction, MessageFunction
  wkt.enum_descriptor_field.<caret>

  # --- EnumValue ---
  # EXPECT-COMPLETE: name, number, options, EnumValueFunction, MessageFunction
  wkt.enum_value_descriptor_field.<caret>

  # --- Field ---
  # EXPECT-COMPLETE: number, name, type_url, oneof_index, packed, options, json_name, default_value, FieldFunction, MessageFunction
