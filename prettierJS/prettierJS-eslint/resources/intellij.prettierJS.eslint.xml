<idea-plugin>

  <dependencies>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <plugin id="intellij.javascript.eslint"/>
    <plugin id="intellij.prettierJS"/>
    <module name="intellij.javascript.backend"/>
    <module name="intellij.javascript.common"/>
    <module name="intellij.javascript.parser"/>
    <module name="intellij.javascript.psi.impl"/>
    <module name="intellij.json.backend"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <eslint.ruleMappersFactory implementation="com.intellij.prettierjs.eslint.PrettierEslintRuleMappersFactory"/>
  </extensions>
</idea-plugin>
