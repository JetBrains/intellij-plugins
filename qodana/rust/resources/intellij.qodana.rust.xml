<idea-plugin>
  <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
  <dependencies>
    <plugin id="com.intellij.modules.rustrover"/>
    <plugin id="com.jetbrains.rust"/>
    <plugin id="org.intellij.qodana"/>
    <module name="intellij.rustrover.core"/>
  </dependencies>
  <!-- endregion -->

  <extensions defaultExtensionNs="com.intellij">
    <activityTracker implementation="org.jetbrains.qodana.rust.QodanaRustLoaderActivityTracker"/>
    <registryKey defaultValue="10" description="Timeout in minutes for Qodana Rust project configuration" key="qd.rust.configuration.timeout.minutes"/>
    <globalInspection hasStaticDescription="true"
                      language="Rust"
                      shortName="QodanaRustSanity"
                      key="inspection.rust.sanity.inspection"
                      bundle="messages.QodanaRustBundle"
                      groupKey="inspection.qodana.tools.group.name"
                      groupBundle="messages.QodanaBundle"
                      enabledByDefault="false"
                      level="ERROR"
                      implementationClass="org.jetbrains.qodana.rust.QodanaRustSanityInspection"/>
  </extensions>
  <extensions defaultExtensionNs="org.intellij">
    <qodana.workflowExtension implementation="org.jetbrains.qodana.rust.QodanaLogRustAnalysisScope"/>
  </extensions>
</idea-plugin>
