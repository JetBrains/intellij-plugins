<idea-plugin>
  <dependencies>
    <plugin id="com.intellij.modules.rustrover"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <plugin id="com.jetbrains.rust"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <postStartupActivity implementation="org.intellij.qodana.rust.QodanaRustLoaderProjectActivity"/>
    <activityTracker implementation="org.intellij.qodana.rust.QodanaRustLoaderActivityTracker"/>
    <registryKey defaultValue="10" description="Timeout in minutes for Qodana Rust project configuration" key="qd.rust.configuration.timeout.minutes"/>
  </extensions>
</idea-plugin>
