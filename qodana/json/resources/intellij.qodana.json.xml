<idea-plugin>
  <dependencies>
    <plugin id="org.intellij.qodana"/>
    <!-- region Generated dependencies - run `Generate Product Layouts` to regenerate -->
    <module name="intellij.json.backend"/>
    <!-- endregion -->
  </dependencies>

  <extensions defaultExtensionNs="com.intellij">
    <fileType name="SARIF" extensions="sarif" patterns="*.sarif.json;*.sarif*.json"
              implementationClass="org.jetbrains.qodana.json.SarifFileType" fieldName="INSTANCE" language="JSON"/>
    <applicationService serviceInterface="org.jetbrains.qodana.filetype.QodanaSarifFileMatcher"
                        serviceImplementation="org.jetbrains.qodana.json.QodanaSarifFileMatcherImpl"/>
  </extensions>
</idea-plugin>
