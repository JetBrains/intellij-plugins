<idea-plugin>
  <dependencies>
    <module name="intellij.maven"/>
  </dependencies>
  <extensions defaultExtensionNs="org.intellij.qodana">
    <projectDescriber implementation="org.jetbrains.qodana.jvm.maven.MavenProjectDescriber"/>
    <workflowExtension implementation="org.jetbrains.qodana.jvm.maven.QodanaSetUserMavenSettings"/>
    <workflowExtension implementation="org.jetbrains.qodana.jvm.maven.QodanaMavenProjectsImporter" />
    <workflowExtension implementation="org.jetbrains.qodana.jvm.maven.QodanaRecoverMavenDependencies" />
    <workflowExtension implementation="org.jetbrains.qodana.jvm.maven.QodanaReimportMavenProjects" />
  </extensions>
  <projectListeners>
    <listener class="org.jetbrains.qodana.jvm.maven.QodanaMavenJdkProvider"
              topic="org.jetbrains.idea.maven.project.MavenImportListener"
              activeInTestMode="false"
              activeInHeadlessMode="true"/>
  </projectListeners>
</idea-plugin>
